__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example
.DS_Store
*.swp
.idea/
.vscode/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
*.db-wal
*.db-shm
.beads-credential-key

# uv / lint / test caches
.uv-cache/
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
dist/
build/

# state / runtime
state/
*.wiki.lock
# Ignore runtime DBs/artifacts under data/, but keep the dir itself (alembic
# upgrades default to relative sqlite:///data/*.db; fresh checkouts/worktrees
# need data/ to exist or scheduler/alembic tests error).
data/*
!data/.gitkeep

# sentrux scratch
.sentrux/baselines/
.sentrux/results/

# total-test run artifacts
.total-test-logs/

# full-audit skill intermediate artifacts
.full_audit_tmp/

# classifier-regress gate stamp (local evidence, not shared state)
.classifier_regress.stamp

# claude worktrees + local settings (never commit)
.claude/

# full-audit history journal (grows per run; rotate manually)
docs/reports/.audit-history.jsonl
