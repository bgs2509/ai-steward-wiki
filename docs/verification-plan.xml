<?xml version="1.0" encoding="utf-8"?>
<VerificationPlan VERSION="0.0.3">
  <GlobalPolicy>
    <log-format>[ModuleName][functionName][BLOCK_NAME] message with structured fields</log-format>
    <log-examples>
      <example-1>[settings][get_settings][LOAD] env=AISW_</example-1>
      <example-2>[allowlist][sync_to_sessions_db][SYNC_DONE] users=N</example-2>
    </log-examples>
    <commands>
      <cmd>uv run pytest tests/unit -q</cmd>
      <cmd>RUN_INTEGRATION=1 uv run pytest tests/integration -q</cmd>
      <cmd>make lint</cmd>
    </commands>
  </GlobalPolicy>

  <Modules>
    <V-M-FOUNDATION-SETTINGS MODULE="M-FOUNDATION-SETTINGS">
      <tests>
        <test path="tests/unit/test_settings.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/test_settings.py -q</cmd>
      </commands>
      <log-markers/>
      <evidence>Settings frozen, env-prefix AISW_, defaults for log_level/workspace/db URLs.</evidence>
    </V-M-FOUNDATION-SETTINGS>

    <V-M-FOUNDATION-LOGGING MODULE="M-FOUNDATION-LOGGING">
      <tests>
        <test path="tests/unit/test_logging_setup.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/test_logging_setup.py -q</cmd>
      </commands>
      <log-markers/>
      <evidence>structlog JSON renderer, ISO UTC timestamps, correlation_id contextvar bound/reset.</evidence>
    </V-M-FOUNDATION-LOGGING>

    <V-M-AUTH-USERS MODULE="M-AUTH-USERS">
      <tests>
        <test path="tests/unit/auth/test_users_toml.py"/>
        <test path="tests/unit/auth/test_allowlist.py"/>
        <test path="tests/unit/auth/test_sighup.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/auth -q</cmd>
      </commands>
      <log-markers/>
      <evidence>users.toml parsed/validated; allowlist atomic swap; SIGHUP+watchdog 500ms debounce; sha256 short-circuit.</evidence>
    </V-M-AUTH-USERS>

    <V-M-STORAGE MODULE="M-STORAGE">
      <tests>
        <test path="tests/unit/storage/test_pragmas.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/storage/test_pragmas.py -q</cmd>
      </commands>
      <log-markers/>
      <evidence>WAL, synchronous=NORMAL, foreign_keys=ON, busy_timeout=5000 applied per connection.</evidence>
    </V-M-STORAGE>

    <V-M-STORAGE-JOBS MODULE="M-STORAGE-JOBS">
      <tests>
        <test path="tests/unit/storage/jobs/test_models.py"/>
        <test path="tests/unit/storage/jobs/test_payloads.py"/>
        <test path="tests/integration/storage/test_jobs_engine.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/storage/jobs -q</cmd>
        <cmd>RUN_INTEGRATION=1 uv run pytest tests/integration/storage/test_jobs_engine.py -q</cmd>
      </commands>
      <log-markers/>
      <evidence>jobs/tracker_answers/jobs_dlq schema; discriminated union round-trips; PRAGMAs verified on engine.</evidence>
    </V-M-STORAGE-JOBS>

    <V-M-STORAGE-AUDIT MODULE="M-STORAGE-AUDIT">
      <tests>
        <test path="tests/unit/storage/audit/test_models.py"/>
        <test path="tests/integration/storage/test_audit_engine.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/storage/audit -q</cmd>
        <cmd>RUN_INTEGRATION=1 uv run pytest tests/integration/storage/test_audit_engine.py -q</cmd>
      </commands>
      <log-markers/>
      <evidence>10 tables present per D-006 amendment; PRAGMAs verified; append-only invariants.</evidence>
    </V-M-STORAGE-AUDIT>

    <V-M-STORAGE-SESSIONS MODULE="M-STORAGE-SESSIONS">
      <tests>
        <test path="tests/unit/storage/sessions/test_models.py"/>
        <test path="tests/integration/storage/test_sessions_engine.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/storage/sessions -q</cmd>
        <cmd>RUN_INTEGRATION=1 uv run pytest tests/integration/storage/test_sessions_engine.py -q</cmd>
      </commands>
      <log-markers/>
      <evidence>users/pending_users/pending_confirms/inbox_hint_cache/fsm tables; PRAGMAs verified.</evidence>
    </V-M-STORAGE-SESSIONS>

    <V-M-RUNTIME-WIRING MODULE="M-RUNTIME-WIRING">
      <tests>
        <test path="tests/unit/test_runtime_wiring.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/test_runtime_wiring.py -q</cmd>
        <cmd>uv run python -m ai_steward_wiki  # manual smoke with AISW_TG_BOT_TOKEN_LOCAL</cmd>
      </commands>
      <log-markers>
        <marker>runtime.start</marker>
        <marker>runtime.migrations.begin</marker>
        <marker>runtime.migrations.done</marker>
        <marker>runtime.allowlist.loaded</marker>
        <marker>runtime.scheduler.started</marker>
        <marker>runtime.polling.start</marker>
        <marker>runtime.signal.received</marker>
        <marker>runtime.shutdown.done</marker>
      </log-markers>
      <evidence>13 unit tests cover sync-URL derivation, data-dir creation, users.toml load fallbacks, signal handler wiring, _amain composition with mocks, missing-token fail-fast, main → asyncio.run. Manual smoke: `python -m ai_steward_wiki` starts, logs polling.start, Ctrl-C → shutdown.done, exit 0.</evidence>
    </V-M-RUNTIME-WIRING>

    <V-M-TG-HANDLERS-WIRING MODULE="M-TG-HANDLERS-WIRING">
      <tests>
        <test path="tests/unit/tg/test_handlers.py"/>
        <test path="tests/unit/tg/test_pipeline.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/tg/test_handlers.py tests/unit/tg/test_pipeline.py -q</cmd>
      </commands>
      <log-markers>
        <marker>tg.pipeline.text.received</marker>
        <marker>tg.pipeline.text.l1_duplicate</marker>
        <marker>tg.pipeline.voice.received</marker>
        <marker>tg.pipeline.voice.no_handler</marker>
        <marker>tg.pipeline.photo.received</marker>
        <marker>tg.pipeline.photo.no_ingestor</marker>
        <marker>tg.pipeline.document.received</marker>
        <marker>tg.pipeline.confirm.received</marker>
        <marker>tg.handlers.callback.malformed</marker>
        <marker>runtime.handlers.registered</marker>
      </log-markers>
      <evidence>28 unit tests cover callback parsing (8 variants), router/dispatcher wiring, _download_bytes, text/voice/photo/document/confirm end-to-end dispatch with fake aiogram Message+CallbackQuery, L1 dedup short-circuit, fallback paths when voice/photo handlers absent.</evidence>
    </V-M-TG-HANDLERS-WIRING>

    <V-M-TG-PIPELINE-CLASSIFIER MODULE="M-TG-PIPELINE-CLASSIFIER">
      <tests>
        <test path="tests/unit/tg/test_pipeline_classifier_wiring.py"/>
        <test path="tests/unit/wiki/test_runner_aggregate.py"/>
        <test path="tests/integration/test_pipeline_classifier_e2e.py"/>
      </tests>
      <commands>
        <cmd>uv run pytest tests/unit/tg/test_pipeline_classifier_wiring.py tests/unit/wiki/test_runner_aggregate.py -q</cmd>
        <cmd>RUN_INTEGRATION=1 uv run pytest tests/integration/test_pipeline_classifier_e2e.py -q</cmd>
      </commands>
      <log-markers>
        <marker>tg.pipeline.classify.begin</marker>
        <marker>tg.pipeline.classify.done</marker>
        <marker>tg.pipeline.classify.error</marker>
        <marker>tg.pipeline.inbox.l2_dedup_hit</marker>
        <marker>tg.pipeline.runner.dispatched</marker>
        <marker>tg.pipeline.runner.completed</marker>
        <marker>tg.pipeline.runner.error</marker>
        <marker>tg.pipeline.deliver.sent</marker>
      </log-markers>
      <evidence>11 unit tests cover text happy path, L1 dup short-circuit, L2 dedup hit (records auto_skip + ACK_DEDUP_RU), classifier error → ACK_CLASSIFY_ERR_RU, runner error → ACK_RUNNER_ERR_RU, empty runner output → ACK_TEXT_RU via deliver, back-compat None injection, voice happy path with transcript, voice empty transcript fallback, voice back-compat legacy ack, structlog markers via capsys. 6 unit tests cover aggregate_text across stream-json payload shapes (message.content text blocks, delta.text, flat text, non-assistant ignore, empty events, unknown shape).</evidence>
    </V-M-TG-PIPELINE-CLASSIFIER>
  </Modules>
</VerificationPlan>
