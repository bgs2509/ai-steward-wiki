# ai-steward-wiki — single env template.
# Copy to `.env` (local dev) or install at /etc/ai-steward-wiki/.env on the VPS
# (mode 0640, owner root:aisw-bot). NEVER commit the populated `.env`.

# === Runtime profile =====================================================
# local — developer machine, picks AISW_TG_BOT_TOKEN_LOCAL.
# vps   — production host, picks AISW_TG_BOT_TOKEN_PROD (required).
AISW_ENV=local

# === Core ================================================================
AISW_LOG_LEVEL=INFO
AISW_WORKSPACE_ROOT=/var/lib/ai-steward-wiki/workspace
AISW_CLAUDE_CONFIG_DIR=/var/lib/ai-steward-wiki/claude-code

# === Telegram ============================================================
# Two separate bots: local test bot + production bot. Only the slot matching
# AISW_ENV is required at startup; the other may stay empty.
AISW_TG_BOT_TOKEN_LOCAL=__SET_ME_LOCAL__
AISW_TG_BOT_TOKEN_PROD=__SET_ME_PROD__
AISW_TG_ADMIN_TELEGRAM_IDS=__SET_ME__

# === Tenancy =============================================================
# single — only admin tenant active. multi — onboarding open.
AISW_TENANCY_MODE=single

# === State DBs (VPS paths; on local pydantic-settings defaults are fine) ==
AISW_JOBS_DB_URL=sqlite+aiosqlite:////var/lib/ai-steward-wiki/state/jobs.db
AISW_AUDIT_DB_URL=sqlite+aiosqlite:////var/lib/ai-steward-wiki/state/audit.db
AISW_SESSIONS_DB_URL=sqlite+aiosqlite:////var/lib/ai-steward-wiki/state/sessions.db
