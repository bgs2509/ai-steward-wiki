# ai-steward-wiki — single env template.
# Copy to `.env` (local dev) or install at /etc/ai-steward-wiki/.env on the VPS
# (mode 0640, owner root:aisw-bot). NEVER commit the populated `.env`.

# === Runtime profile =====================================================
# local — developer machine, picks AISW_TG_BOT_TOKEN_LOCAL.
# vps   — production host, picks AISW_TG_BOT_TOKEN_PROD (required).
AISW_ENV=local

# === Core ================================================================
AISW_LOG_LEVEL=INFO
# XDG layout: local ~/.local/share/ai-steward-wiki/, VPS /var/lib/ai-steward-wiki/.
# Keep runtime state out of the repo (SQLite, wikis, claude-code auth).
# Each path is read independently — workspace_root does NOT cascade.
# Pre-create directories: mkdir -p .../workspace/wikis .../state/snapshots .../claude-code
AISW_WORKSPACE_ROOT=/home/users/.local/share/ai-steward-wiki/workspace
AISW_WIKI_ROOT=/home/users/.local/share/ai-steward-wiki/workspace/wikis
AISW_SNAPSHOT_DIR=/home/users/.local/share/ai-steward-wiki/state/snapshots

# Read-only assets shipped with the repo — point to checkout location on local.
# VPS: /opt/ai-steward-wiki/{prompts,templates} (deploy layout).
AISW_PROMPTS_DIR=/home/users/ai-steward/Gena_Beeline_Local/ai-steward-wiki/prompts
AISW_WIKI_TEMPLATE_DIR=/home/users/ai-steward/Gena_Beeline_Local/ai-steward-wiki/templates

# Claude Code CLI config dir — picked by AISW_ENV.
# Local: dedicated XDG path isolates bot's subscription auth from developer's ~/.claude/.
#        Run once: CLAUDE_CONFIG_DIR=/home/users/.local/share/ai-steward-wiki/claude-code claude login
# VPS:   leave AISW_CLAUDE_CONFIG_DIR_VPS unset → CLI uses default ~/.claude/.
AISW_CLAUDE_CONFIG_DIR_LOCAL=/home/users/.local/share/ai-steward-wiki/claude-code
# AISW_CLAUDE_CONFIG_DIR_VPS=

# === Telegram ============================================================
# Two separate bots: local test bot + production bot. Only the slot matching
# AISW_ENV is required at startup; the other may stay empty.
# @LOCAL_BOT
AISW_TG_BOT_TOKEN_LOCAL=__SET_ME_LOCAL__
# @VPS_BOT
AISW_TG_BOT_TOKEN_PROD=__SET_ME_PROD__
# @ADMIN_ID
AISW_TG_ADMIN_TELEGRAM_IDS=__LIST_OF_IDS__

# === Tenancy =============================================================
# single — only admin tenant active. multi — onboarding open.
AISW_TENANCY_MODE=single

# === State DBs (VPS paths; on local pydantic-settings defaults are fine) ==
AISW_JOBS_DB_URL=sqlite+aiosqlite:///data/jobs.db
AISW_AUDIT_DB_URL=sqlite+aiosqlite:///data/audit.db
AISW_SESSIONS_DB_URL=sqlite+aiosqlite:///data/sessions.db

# === Allowlist ===========================================================
# Path to users.toml (schema_version, [[users]] with telegram_id + role).
# Unset or missing file → empty allowlist (every non-admin update gets auth.deny).
# Local: data/users.toml. VPS: /etc/ai-steward-wiki/users.toml (mode 0640).
AISW_USERS_TOML_PATH=data/users.toml

# === Profiles (aisw-0a5: migration) ======================================
# Per-user free-form profile notes (persona, interests, tone). Read by
# classifier/wiki prompts as `<user_profile>{md_content}</user_profile>` if
# the file `<id>.md` exists. Empty dir at migration time (Q6/V4: re-onboarding
# fills these); no migration of legacy profile prose.
# Consumed as the argparse default for `python -m ai_steward_wiki.migration
# --profiles-dir` (CLI flag overrides this env value).
AISW_PROFILES_DIR=/home/users/.local/share/ai-steward-wiki/data/profiles

# === Media handling (D-022) ==============================================
# Voice → faster-whisper STT (small/medium CPU int8). Photo → vision-staged.
# Staging is per-sender under <wiki_root>/<telegram_id>/Inbox-WIKI/raw/media/_staging
# (see inbox.materialize.inbox_wiki_path, aisw-12t Phase-E.a) — no global root env.
AISW_VOICE_ENABLED=true
AISW_VOICE_WHISPER_MODEL_SIZE=small
AISW_VOICE_STT_TIMEOUT_S=60
AISW_PHOTO_ENABLED=true
AISW_PHOTO_VISION_TIMEOUT_S=30

# === PII redaction (M-OPS-PII, D-034 §10.4) ==============================
# REQUIRED IN PRODUCTION. Salt for HMAC-based PII hashing (audit sha8 fields).
# The compiled-in default is publicly known — leaving it unchanged means all
# hashed values are precomputable. Generate once per deployment and keep secret.
#   openssl rand -hex 32
AISW_PII_HASH_SECRET=__GENERATE_WITH_openssl_rand_-hex_32__
# Drop/mask toggles (true = active). Set false only for debugging locally.
AISW_PII_DROP_ENABLED=true
AISW_PII_MASK_ENABLED=true
# Dry-run: log what would be purged without deleting. Set true in staging.
AISW_RETENTION_DRY_RUN=false

# === L2 ingest dedup TTL (D-018 amended 2026-05-13, ADR-028) =============
# Per-kind window for seen_files: text/voice short (retry-storm), photo/file long (artifact).
AISW_L2_TTL_TEXT_SECONDS=60
AISW_L2_TTL_BINARY_SECONDS=2592000
