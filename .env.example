# ai-steward-wiki — example environment.
# Copy to `.env` and adjust per host. NEVER commit `.env`.
# Fields are added incrementally per chunk; this skeleton covers Chunk 1.

AISW_LOG_LEVEL=INFO
AISW_WORKSPACE_ROOT=/var/lib/ai-steward-wiki/workspace
AISW_CLAUDE_CONFIG_DIR=/var/lib/ai-steward-wiki/claude-code
